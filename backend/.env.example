# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
PORT=8080

# Supabase Configuration
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# JWT (used for signing access/refresh tokens)
JWT_SECRET="your-jwt-secret"

# Google OAuth Client IDs
GOOGLE_CLIENT_ID_WEB="your-google-client-id-web.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_IOS="your-google-client-id-ios.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_ANDROID="your-google-client-id-android.apps.googleusercontent.com"

# Brevo Email (HTTP API — works on Render, no SMTP port blocking)
# BREVO_API_KEY: get from Brevo dashboard → SMTP & API → API keys & MCP tab → Create API key
# SMTP_SENDER_EMAIL: must be a verified sender in your Brevo account
# SMTP_SENDER_NAME: display name shown in recipient's inbox
BREVO_API_KEY="xkeysib-your-brevo-api-key-here"
SMTP_SENDER_NAME="Upcheck"
SMTP_SENDER_EMAIL="admin@upcheck.in"

# CORS (use "*" for mobile apps, or comma-separated origins for web)
CORS_ORIGIN="*"

# Truecaller Configuration (server-side verification)
# Legacy fields used by older flows. Kept for backwards compatibility; the
# Truecaller SDK 2.6.0 verifier uses the variables below.
TRUECALLER_APP_KEY="your-truecaller-app-key"
TRUECALLER_APP_SECRET="your-truecaller-app-secret"

# Truecaller SDK 2.6.0 verifier (TruecallerService)
# Public-key cache TTL in seconds. Clamped to [3600, 86400] per Requirement 9.2.
# Default: 3600 (1 hour).
TRUECALLER_PUBLIC_KEY_TTL_SECONDS=3600
# Nonce replay-store TTL in seconds. Floor of 600 enforced per Requirement 9.7.
# Default: 600 (10 minutes).
TRUECALLER_NONCE_TTL_SECONDS=600
# Profile API used for Flow B (OTP / missed-call access-token exchange).
TRUECALLER_PROFILE_API_URL="https://api5.truecaller.com/v1/otp/installation/verify/profile"
# RSA public-key endpoint used for Flow A (One-Tap signature verification).
TRUECALLER_KEYS_API_URL="https://api4.truecaller.com/v1/key"

# Environment
NODE_ENV="development"
FRONTEND_URL="upcheck://"
