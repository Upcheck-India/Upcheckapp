# Truecaller SDK Partner Key (do not commit real keys)
# Real partner key lives in this file at build time; it is merged into the same
# string resource pool as strings.xml so AndroidManifest.xml references like
# @string/partnerKey resolve correctly. Provide it via your secret store before
# building.
frontend/android/app/src/main/res/values/partner-keys.xml

# local-only live auth smoke test (references gitignored .env)
backend/scripts/auth-smoke.sh

# large binary design doc — keep out of git (use lfs if ever needed)
Upcheck_Architecture_UX_Document.docx
