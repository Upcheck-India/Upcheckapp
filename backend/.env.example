# =============================================================================
# Backend environment — also the Render "Environment" checklist for the cutover.
# [SECRET] = set in the Render dashboard, never commit. [public] = safe to share.
# Copy each value from the NEW Supabase / Brevo project.
# =============================================================================

# [SECRET] Database. TWO different URLs depending on context:
#   • ON RENDER: use the POOLER (Transaction) URL — Supabase → Database → Connection
#     string → "Transaction pooler" (host aws-0-<region>.pooler.supabase.com:6543).
#     Render has no IPv6 egress, so the DIRECT host (db.<ref>.supabase.co) HANGS.
#   • RUNNING MIGRATIONS (once, from your laptop): use the DIRECT/Session URL
#     (port 5432) — migrations need DDL + RLS owner rights the txn-pooler can't do.
DATABASE_URL="postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres"
PORT=10000

# Supabase — Settings → API
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"          # [public]
SUPABASE_ANON_KEY="your-supabase-anon-key"               # [public] (RLS-locked)
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"           # [SECRET]
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key" # [SECRET]

# [SECRET] App JWT signing secret — any strong random string.
JWT_SECRET="your-jwt-secret"

# Google OAuth Client IDs (unchanged unless you made a new Google project). [public]
GOOGLE_CLIENT_ID_WEB="your-google-client-id-web.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_IOS="your-google-client-id-ios.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_ANDROID="your-google-client-id-android.apps.googleusercontent.com"

# Brevo email — Brevo → SMTP & API → API keys. SMTP_SENDER_EMAIL must be a
# VERIFIED sender in Brevo (verify the sender/domain first or mail won't send).
BREVO_API_KEY="xkeysib-your-brevo-api-key-here"          # [SECRET]
SMTP_SENDER_NAME="Upcheck"
SMTP_SENDER_EMAIL="admin@yourdomain.com"

# CORS (mobile app → keep "*").
CORS_ORIGIN="*"

# IMPORTANT: must equal the Expo app scheme so the password-reset deep link
# (FRONTEND_URL/reset-password) opens the app. Do NOT use "upcheck://".
FRONTEND_URL="upcheckapp://"

# [SECRET, optional] Redis — used for 2FA temp tokens + Truecaller replay store.
# Omit to fall back to an in-memory store (fine for a single instance).
REDIS_URL="redis://default:PASSWORD@host:port"

# Truecaller (server-side verification) — unchanged unless you made a new key.
TRUECALLER_APP_KEY="your-truecaller-app-key"
TRUECALLER_APP_SECRET="your-truecaller-app-secret"
TRUECALLER_PUBLIC_KEY_TTL_SECONDS=3600
TRUECALLER_NONCE_TTL_SECONDS=600
TRUECALLER_PROFILE_API_URL="https://api5.truecaller.com/v1/otp/installation/verify/profile"
TRUECALLER_KEYS_API_URL="https://api4.truecaller.com/v1/key"

NODE_ENV="production"
