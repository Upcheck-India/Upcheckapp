# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
PORT=8080

# Supabase Configuration
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# JWT (used for signing access/refresh tokens)
JWT_SECRET="your-jwt-secret"

# Google OAuth Client IDs
GOOGLE_CLIENT_ID_WEB="your-google-client-id-web.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_IOS="your-google-client-id-ios.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_ANDROID="your-google-client-id-android.apps.googleusercontent.com"

# SMTP Configuration (Nodemailer)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user@example.com"
SMTP_PASS="your-smtp-password"
SMTP_SENDER_NAME="Upcheck"
SMTP_SENDER_EMAIL="your-sender@example.com"

# CORS (use "*" for mobile apps, or comma-separated origins for web)
CORS_ORIGIN="*"

# Environment
NODE_ENV="development"
FRONTEND_URL="upcheck://"
